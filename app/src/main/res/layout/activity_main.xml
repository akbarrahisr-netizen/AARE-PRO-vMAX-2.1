<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🚂 TRAIN DETAILS"
            android:textColor="#7E57C2"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etTrainNumber"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="#2C2C2C"
            android:padding="12dp"
            android:hint="Train Number (5 Digits)"
            android:inputType="number"
            android:maxLength="5"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:layout_marginBottom="12dp"
            android:importantForAutofill="no"
            android:imeOptions="actionNext"
            android:maxLines="1"/>

        <EditText
            android:id="@+id/etClass"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="#2C2C2C"
            android:padding="12dp"
            android:hint="Class (SL / 3A)"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:layout_marginBottom="8dp"
            android:focusable="false"
            android:clickable="true"
            android:cursorVisible="false"
            android:importantForAutofill="no"
            android:imeOptions="actionNext"
            android:maxLines="1"/>

        <EditText
            android:id="@+id/etLatency"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="#2C2C2C"
            android:padding="12dp"
            android:hint="Latency Offset (ms) - Default: 400"
            android:inputType="number"
            android:maxLength="4"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:layout_marginBottom="20dp"
            android:importantForAutofill="no"
            android:imeOptions="actionNext"
            android:maxLines="1"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👥 PASSENGER 1"
            android:textColor="#7E57C2"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etName1"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="#2C2C2C"
            android:padding="12dp"
            android:hint="Name (4-16 chars)"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:layout_marginBottom="8dp"
            android:importantForAutofill="no"
            android:imeOptions="actionNext"
            android:maxLines="1"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <EditText
                android:id="@+id/etAge1"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="#2C2C2C"
                android:padding="12dp"
                android:hint="Age (1-199)"
                android:inputType="number"
                android:maxLength="3"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:importantForAutofill="no"
                android:imeOptions="actionNext"
                android:maxLines="1"/>

            <EditText
                android:id="@+id/etGender1"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:background="#2C2C2C"
                android:padding="12dp"
                android:hint="Gender"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:focusable="false"
                android:clickable="true"
                android:cursorVisible="false"
                android:importantForAutofill="no"
                android:imeOptions="actionNext"
                android:maxLines="1"/>
        </LinearLayout>

        <EditText
            android:id="@+id/etMeal1"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="#2C2C2C"
            android:padding="12dp"
            android:hint="Meal Preference (Veg/Non-Veg/No Food)"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:focusable="false"
            android:clickable="true"
            android:cursorVisible="false"
            android:importantForAutofill="no"
            android:imeOptions="actionNext"
            android:maxLines="1"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👥 PASSENGER 2 (Optional)"
            android:textColor="#7E57C2"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etName2"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="#2C2C2C"
            android:padding="12dp"
            android:hint="Name (Optional)"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:layout_marginBottom="8dp"
            android:importantForAutofill="no"
            android:imeOptions="actionNext"
            android:maxLines="1"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <EditText
                android:id="@+id/etAge2"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="#2C2C2C"
                android:padding="12dp"
                android:hint="Age"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:importantForAutofill="no"
                android:imeOptions="actionNext"
                android:maxLines="1"/>

            <EditText
                android:id="@+id/etGender2"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:background="#2C2C2C"
                android:padding="12dp"
                android:hint="Gender"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:focusable="false"
                android:clickable="true"
                android:cursorVisible="false"
                android:importantForAutofill="no"
                android:imeOptions="actionNext"
                android:maxLines="1"/>
        </LinearLayout>

        <EditText
            android:id="@+id/etMeal2"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="#2C2C2C"
            android:padding="12dp"
            android:hint="Meal Preference (Optional)"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:focusable="false"
            android:clickable="true"
            android:cursorVisible="false"
            android:importantForAutofill="no"
            android:imeOptions="actionNext"
            android:maxLines="1"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👥 PASSENGER 3 (Optional)"
            android:textColor="#7E57C2"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etName3"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="#2C2C2C"
            android:padding="12dp"
            android:hint="Name (Optional)"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:layout_marginBottom="8dp"
            android:importantForAutofill="no"
            android:imeOptions="actionNext"
            android:maxLines="1"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <EditText
                android:id="@+id/etAge3"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="#2C2C2C"
                android:padding="12dp"
                android:hint="Age"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:importantForAutofill="no"
                android:imeOptions="actionNext"
                android:maxLines="1"/>

            <EditText
                android:id="@+id/etGender3"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:background="#2C2C2C"
                android:padding="12dp"
                android:hint="Gender"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:focusable="false"
                android:clickable="true"
                android:cursorVisible="false"
                android:importantForAutofill="no"
                android:imeOptions="actionNext"
                android:maxLines="1"/>
        </LinearLayout>

        <EditText
            android:id="@+id/etMeal3"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="#2C2C2C"
            android:padding="12dp"
            android:hint="Meal Preference (Optional)"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:focusable="false"
            android:clickable="true"
            android:cursorVisible="false"
            android:importantForAutofill="no"
            android:imeOptions="actionNext"
            android:maxLines="1"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👥 PASSENGER 4 (Optional)"
            android:textColor="#7E57C2"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etName4"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="#2C2C2C"
            android:padding="12dp"
            android:hint="Name (Optional)"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:layout_marginBottom="8dp"
            android:importantForAutofill="no"
            android:imeOptions="actionNext"
            android:maxLines="1"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <EditText
                android:id="@+id/etAge4"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="#2C2C2C"
                android:padding="12dp"
                android:hint="Age"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:importantForAutofill="no"
                android:imeOptions="actionDone"
                android:maxLines="1"/>

            <EditText
                android:id="@+id/etGender4"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:background="#2C2C2C"
                android:padding="12dp"
                android:hint="Gender"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:focusable="false"
                android:clickable="true"
                android:cursorVisible="false"
                android:importantForAutofill="no"
                android:imeOptions="actionDone"
                android:maxLines="1"/>
        </LinearLayout>

        <EditText
            android:id="@+id/etMeal4"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="#2C2C2C"
            android:padding="12dp"
            android:hint="Meal Preference (Optional)"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:focusable="false"
            android:clickable="true"
            android:cursorVisible="false"
            android:importantForAutofill="no"
            android:imeOptions="actionDone"
            android:maxLines="1"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙️ ADVANCED CONTROLS"
            android:textColor="#FFB74D"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <CheckBox
            android:id="@+id/cbAutoUpgrade"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Consider Auto Upgradation"
            android:textColor="#FFFFFF"
            android:buttonTint="#FFB74D"
            android:layout_marginBottom="8dp"/>

        <CheckBox
            android:id="@+id/cbConfirmOnly"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Book ONLY if confirm berths"
            android:textColor="#FFFFFF"
            android:buttonTint="#FFB74D"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💳 VIP PAYMENT BOARD"
            android:textColor="#00E676"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etPaymentMethod"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="#2C2C2C"
            android:padding="12dp"
            android:hint="Payment App (PhonePe / Paytm / Mobikwik / UPI)"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:focusable="false"
            android:clickable="true"
            android:cursorVisible="false"
            android:importantForAutofill="no"
            android:imeOptions="actionDone"
            android:maxLines="1"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnSaveProfile"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="🔥 ARM THE SNIPER (SAVE)"
            android:backgroundTint="#D32F2F"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvProfileStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Waiting for Command..."
            android:textColor="#7E57C2"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="30dp"/>

    </LinearLayout>
</ScrollView>
