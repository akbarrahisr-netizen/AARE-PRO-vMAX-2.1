<resources>
    <string name="app_name">VMAX Pro Sniper</string>
    
    <string name="accessibility_service_description">
        VMAX Pro Sniper helps automate IRCTC Tatkal booking by auto-filling passenger details and solving captcha automatically. 
        It supports UPI payment apps for a seamless booking experience. 
        This tool interacts only with the official IRCTC app for testing and automation purposes, 
        ensuring no personal data is collected or shared. 
        You can disable accessibility service anytime in Settings.
    </string>
    
